# ─── cShot Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in the values you need.
# All keys are OPTIONAL. Mock DSP generation works without any keys.
#
#   cp .env.example .env
#
# ─── Provider API Keys ───────────────────────────────────────────
#
# ElevenLabs Text-to-Sound-Effects — https://elevenlabs.io
# Best quality for one-shot sound effects. Recommended for MVP.
# Sign up: https://elevenlabs.io/app/sound-effects
# Pricing: ~$0.10/generation at standard tier
CSHOT_ELEVENLABS_API_KEY=
#
# Stable Audio API — https://stability.ai/stable-audio
# High-quality audio generation. Self-hostable model available.
# Sign up: https://platform.stability.ai/
CSHOT_STABLEAUDIO_API_KEY=
#
# Hugging Face Inference API — https://huggingface.co/inference-api
# For AudioLDM 2 and other open models
CSHOT_HUGGINGFACE_API_KEY=
#
# ─── Provider Selection ──────────────────────────────────────────
#
# Override the active provider. If unset or unavailable, falls back
# to mock-dsp. Valid values: mock-dsp, elevenlabs, stable-audio, audioldm2
# CSHOT_ACTIVE_PROVIDER=elevenlabs
#
# ─── Bakeoff Config ──────────────────────────────────────────────
#
# Directory to store bakeoff results. Default: ~/cShot/bakeoff/
# CSHOT_BAKEOFF_DIR=~/cShot/bakeoff
