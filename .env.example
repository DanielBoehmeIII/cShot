# ─── cShot Environment Configuration ─────────────────────────────
# Copy this file to .env only if you want to configure cloud providers.
# cShot's local engine works immediately with NO configuration needed.
#
#   cp .env.example .env   (only if you need cloud providers)
#
# ─── Provider API Keys (Completely Optional) ─────────────────────
#
# cShot is local-first. The local engine works without any keys.
# These API keys are for optional cloud provider integration.
# Generation will never fail or block if these are missing.
#
# ElevenLabs Text-to-Sound-Effects — https://elevenlabs.io
# CSHOT_ELEVENLABS_API_KEY=
#
# Stable Audio API — https://stability.ai/stable-audio
# CSHOT_STABLEAUDIO_API_KEY=
#
# Hugging Face Inference API — https://huggingface.co/inference-api
# CSHOT_HUGGINGFACE_API_KEY=
#
# ─── Provider Selection ──────────────────────────────────────────
#
# The local engine (cshot-engine) is always the default.
# To use a cloud provider, select it in the app's provider dropdown.
# CSHOT_ACTIVE_PROVIDER=elevenlabs
#
# ─── Bakeoff Config ──────────────────────────────────────────────
#
# Directory to store bakeoff results. Default: ~/cShot/bakeoff/
# CSHOT_BAKEOFF_DIR=~/cShot/bakeoff
